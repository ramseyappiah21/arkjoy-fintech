# Auth
AUTH_SECRET=replace-with-a-long-random-string

# Paystack (Ghana MoMo — real telco charges)
# Get keys: https://dashboard.paystack.com/#/settings/developer
#
# sk_test_... / pk_test_... = SIMULATION only (no real phone prompts)
# sk_live_... / pk_live_... = REAL MoMo charges (requires Paystack compliance approved)
#
# Go live: Dashboard → Settings → Compliance → submit documents → wait for approval
# Then toggle to Live mode and copy Live Secret + Public keys here.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Optional: dedicated webhook secret. Defaults to PAYSTACK_SECRET_KEY for HMAC.
# Webhook URL (Paystack dashboard): https://YOUR_DOMAIN/api/webhooks/paystack
# Events: charge.success, transfer.success, transfer.failed
PAYSTACK_WEBHOOK_SECRET=

# Local only — never enable in production
# PAYSTACK_SKIP_WEBHOOK_VERIFY=true
